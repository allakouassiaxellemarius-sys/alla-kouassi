generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  avatar    String?
  bio       String?
  country   String?
  twitter   String?
  discord   String?
  role      String   @default("user")
  banned    Boolean  @default(false)
  banReason String?
  deviceId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams        TeamMember[]
  tournaments  TournamentOrganizer[]
  matches      MatchPlayer[]
  notifications Notification[]
  disputes     Dispute[]
  badges       Badge[]
  reports      Report[]
}

model Team {
  id          String   @id @default(uuid())
  name        String   @unique
  tag         String
  logo        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members   TeamMember[]
  tournaments TournamentTeam[]
}

model TeamMember {
  id      String @id @default(uuid())
  userId  String
  teamId  String
  role    String @default("member")
  user    User   @relation(fields: [userId], references: [id])
  team    Team   @relation(fields: [teamId], references: [id])
}

model Tournament {
  id            String   @id @default(uuid())
  name          String
  description   String?
  game          String?
  maxTeams      Int      @default(16)
  minTeams      Int      @default(2)
  prizePool     String?
  startDate     DateTime?
  endDate       DateTime?
  status        String   @default("upcoming")
  format        String   @default("single_elimination")
  level         String   @default("all")
  region        String?
  matchDuration Int?
  pointsForWin  Int      @default(3)
  pointsForDraw Int      @default(1)
  pointsForLoss Int      @default(0)
  allowDraw     Boolean  @default(false)
  registrationType String @default("auto")
  rules         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organizers    TournamentOrganizer[]
  teams         TournamentTeam[]
  matches       Match[]
  disputes      Dispute[]
  notifications Notification[]
}

model TournamentOrganizer {
  id            String     @id @default(uuid())
  userId        String
  tournamentId  String      @unique
  user          User       @relation(fields: [userId], references: [id])
  tournament    Tournament @relation(fields: [tournamentId], references: [id])
}

model TournamentTeam {
  id            String     @id @default(uuid())
  teamId        String
  tournamentId  String
  seed          Int?
  status        String     @default("registered")
  approvalStatus String    @default("approved")
  points        Int        @default(0)
  team          Team       @relation(fields: [teamId], references: [id])
  tournament    Tournament @relation(fields: [tournamentId], references: [id])
}

model Match {
  id              String   @id @default(uuid())
  tournamentId    String
  round           Int
  matchIndex      Int
  team1Id         String?
  team2Id         String?
  winnerId        String?
  score1          Int?
  score2          Int?
  scoreStatus     String   @default("pending")
  status          String   @default("scheduled")
  scheduledAt     DateTime?
  playedAt        DateTime?
  delayed         Boolean  @default(false)
  delayReason     String?
  delayReportedBy String?
  scoreReportedBy String?
  scoreApprovedBy String?
  spectatorCount  Int      @default(0)
  streamUrl       String?
  log             String   @default("[]")
  createdAt       DateTime @default(now())

  tournament      Tournament @relation(fields: [tournamentId], references: [id])
  players         MatchPlayer[]
  disputes        Dispute[]
  badges          Badge[]
}

model Badge {
  id          String   @id @default(uuid())
  userId      String
  matchId     String?
  type        String
  name        String
  description String
  icon        String   @default("🏆")
  earnedAt    DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  match       Match?   @relation(fields: [matchId], references: [id])
}

model MatchPlayer {
  id      String @id @default(uuid())
  matchId String
  userId  String
  teamId  String?
  match   Match  @relation(fields: [matchId], references: [id])
  user    User   @relation(fields: [userId], references: [id])
}

model Notification {
  id           String   @id @default(uuid())
  userId       String
  type         String   @default("info")
  title        String
  message      String
  link         String?
  tournamentId String?
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  tournament Tournament? @relation(fields: [tournamentId], references: [id])
}

model ResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Report {
  id          String   @id @default(uuid())
  reporterId  String
  targetId    String
  targetType  String   @default("user")
  reason      String
  description String?
  status      String   @default("open")
  createdAt   DateTime @default(now())

  reporter    User     @relation(fields: [reporterId], references: [id])
}

model Dispute {
  id          String   @id @default(uuid())
  matchId     String
  tournamentId String
  reportedBy  String
  reason      String
  details     String?
  status      String   @default("open")
  resolvedBy  String?
  resolution  String?
  targetTeamId String?
  createdAt   DateTime @default(now())

  match      Match      @relation(fields: [matchId], references: [id])
  tournament Tournament @relation(fields: [tournamentId], references: [id])
  reporter   User       @relation(fields: [reportedBy], references: [id])
}
