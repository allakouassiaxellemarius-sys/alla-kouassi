{
  "name": "competition-platform",
  "version": "1.0.0",
  "description": "Plateforme de compétition eSport",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "build:vercel": "npx prisma generate --schema=server/prisma/schema.prisma && cd client && npm install && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prisma": "^6.6.0"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.1.0",
    "vercel": "^54.12.2"
  }
}
